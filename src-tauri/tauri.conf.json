{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReelOne",
  "version": "0.1.0",
  "identifier": "com.reelone.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ReelOne",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Multi-angle reels, live broadcasting, tournaments — for every game.",
    "longDescription": "ReelOne stitches your gameplay clips into multi-angle reels using YouTube's 'most replayed' heatmap, runs tournaments, tracks power levels, and lets squads broadcast together via local OBS — your stream keys, your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {}
}
