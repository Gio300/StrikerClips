# --- Required for app to load ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Deploy base path (GitHub Pages) ---
# Today the live deploy is /StrikerClips/. Change this when you rename the GitHub repo.
# Example: VITE_BASE_PATH=/ShinobiVillage/
VITE_BASE_PATH=/StrikerClips/

# --- AdSense (optional, leave empty to disable) ---
# Get a client ID from https://www.google.com/adsense/
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_RANKINGS_HERO=
VITE_ADSENSE_RANKINGS_BETWEEN=
VITE_ADSENSE_STAT_CHECK_HERO=
VITE_ADSENSE_STAT_CHECK_BETWEEN=
VITE_ADSENSE_SCREENSHOTS_SUBMIT=
VITE_ADSENSE_REEL_PREROLL=
# Creation gate: full-width ad before a free user can submit a new reel.
VITE_ADSENSE_CREATE_GATE=
# Future: before MP3/MP4 export without Pro.
VITE_ADSENSE_EXPORT_GATE=

# Seconds a free user must view the create-gate sponsor (30 default). Set 0 in dev to skip.
VITE_CREATION_AD_SECONDS=30
# Set 1 in .env.local to simulate Pro (bypasses sponsor on create)
VITE_DEV_PREMIUM=

# --- Marketing / download buttons (point to GitHub Releases / store URLs once shipped) ---
VITE_DOWNLOAD_WIN=
VITE_DOWNLOAD_MAC=
VITE_DOWNLOAD_LINUX=
VITE_DOWNLOAD_IOS=
VITE_DOWNLOAD_ANDROID=

# --- Standalone marketing site (used by `npm run build:site`) ---
# Sub-path if hosted under a folder (e.g. /reelone/). Default '/'.
VITE_SITE_BASE=/
# Absolute URL of the deployed app. When set, marketing CTAs deep-link there.
# Example: VITE_APP_URL=https://gio300.github.io/StrikerClips
VITE_APP_URL=
# Optional one-click contact button on the marketing site.
VITE_CONTACT_EMAIL=

# --- Social share / OAuth (optional) ---
# Google + Facebook social login is configured in Supabase Dashboard
# (Auth -> Providers). The frontend just calls signInWithOAuth.
#
# A Facebook App ID here unlocks the proper Messenger Send Dialog in
# share buttons (works on desktop + mobile). Without it we fall back to
# the fb-messenger:// deep link, which only works if Messenger is installed.
VITE_FACEBOOK_APP_ID=

# --- For scripts/send-announcement.ts (mass email) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GMAIL_USER=shinobivillage@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
ANNOUNCEMENT_SUBJECT=ReelOne Announcement
